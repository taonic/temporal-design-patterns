{
  "name": "temporal-design-patterns",
  "version": "1.0.0",
  "description": "Common catalog of reusable patterns for Temporal workflows",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "sandbox": "bash -lc 'npm --prefix sandbox-runner run start'",
    "sandbox:dev": "bash -lc 'npm --prefix sandbox-runner run dev'",
    "dev": "concurrently -n docs,sandbox -c blue,green \"npm run docs:dev\" \"npm run sandbox:dev\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "vitepress": "^1.0.0",
    "vitepress-plugin-mermaid": "^2.0.16"
  },
  "dependencies": {
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "codemirror": "^6.0.2"
  }
}
